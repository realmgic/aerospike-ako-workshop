# Main workshop cluster environment
# Copy to workshop.env and customize. Never commit workshop.env (contains no secrets by default).

CLUSTER_NAME=my-cluster
AWS_REGION=us-east-1
DEPLOY_PATH=olm                    # olm | helm
NODE_PROVISIONING=eksctl           # eksctl | karpenter

# Section 1 Lab 1.1 + Section 2 cluster storage (disk = local-ssd device; dim = in-memory)
CLUSTER_STORAGE=disk               # disk | dim
# Per-lab overrides (comma-separated lab IDs, e.g. 1.1,2.5)
CLUSTER_STORAGE_DIM_LABS=            # when CLUSTER_STORAGE=disk, these labs use dim
CLUSTER_STORAGE_DISK_LABS=           # when CLUSTER_STORAGE=dim, these labs use disk

# Karpenter (main cluster only — Lab 2.6 upgrade-lab stays on eksctl MNG)
KARPENTER_VERSION=1.11.2
KARPENTER_NAMESPACE=karpenter
KARPENTER_CONSOLIDATION=WhenEmpty    # WhenEmpty | WhenEmptyOrUnderutilized; Off = workshop alias -> WhenEmpty + 720h consolidateAfter
KARPENTER_SYSTEM_NODEGROUP=ng-system
KARPENTER_SYSTEM_NODE_TYPE=t3.large
KARPENTER_SYSTEM_NODE_COUNT=2
KARPENTER_NODEPOOL_NAME=aerospike-i8g       # per-AZ NodePools: ${KARPENTER_NODEPOOL_NAME}-<zone>
KARPENTER_NODEPOOL_VERTICAL_NAME=aerospike-i8g-4xl
KARPENTER_NODECLASS_NAME=aerospike-i8g

AWS_ZONES=us-east-1c,us-east-1d   # cluster AZs; rack YAML rendered via NODE_ZONE_A/B from this list
NODE_ZONE=us-east-1c                # upgrade-lab cluster only; main path uses AWS_ZONES
MIN_NODES_PER_ZONE=2                # minimum Ready nodes per zone for rack labs (size 4, 2 racks)
NODEGROUP_NAME=ng-aerospike         # per-AZ MNGs: ${NODEGROUP_NAME}-<zone> (e.g. ng-aerospike-us-east-1c)
NODEGROUP_NAME_VERTICAL=ng-aerospike-4xl
NODE_TYPE=i8g.2xlarge
NODE_TYPE_VERTICAL=i8g.4xlarge
NODE_COUNT=4
# Force nvme-bootstrap layout key (empty = detect via IMDS instance-type)
NVME_DISK_LAYOUT=
K8S_VERSION=1.33

# Upgrade-lab cluster (Lab 2.6 only)
UPGRADE_LAB_CLUSTER_NAME=my-cluster-k8s-upgrade
UPGRADE_LAB_K8S_VERSION_START=1.31
UPGRADE_LAB_K8S_VERSION_TARGET=1.32
UPGRADE_LAB_NODE_COUNT=3
UPGRADE_LAB_NODE_TYPE=i8g.2xlarge
UPGRADE_LAB_AEROSPIKE_SIZE=3

# AKO versions
# AKO_VERSION_START — operator install pin (Lab 0.3 only)
# AKO_VERSION_TARGET — curriculum end-state after full Lab 2.2 ladder (4.5.0)
# AKO_CLUSTER_CHART_VERSION — optional override for aerospike-cluster chart --version;
#   leave empty to auto-detect installed operator (4.4.1 or 4.5.0 after Lab 2.2)
AKO_VERSION_START=4.2.0
AKO_VERSION_TARGET=4.5.0
AKO_UPGRADE_LADDER=4.2.0,4.3.0,4.4.1,4.5.0
AKO_MIN_VERSION_REPLICATION_FACTOR=4.4.0
AKO_CLUSTER_CHART_VERSION=

# OLM / Helm
OLM_VERSION=v0.43.0
HELM_REPO=https://aerospike.github.io/aerospike-kubernetes-enterprise
HELM_OPERATOR_RELEASE=aerospike-kubernetes-operator
HELM_CLUSTER_RELEASE=aerocluster

# Namespaces
NAMESPACE=aerospike
OPERATOR_NAMESPACE=operators

# Paths (relative to workshop/)
SSH_PUBLIC_KEY=your-ec2-key-name
OPERATOR_REPO=aerospike-kubernetes-operator
FEATURES_CONF_PATH=secrets/features.conf

# Aerospike Database: baseline 8.1.0.x (AKO 4.2.0–4.4.1); upgrade target 8.1.2.x after AKO 4.5.0 (Lab 2.4)
AEROSPIKE_VERSION=8.1.0
AEROSPIKE_IMAGE=aerospike/aerospike-server-enterprise:8.1.0.0
AEROSPIKE_UPGRADE_IMAGE=aerospike/aerospike-server-enterprise:8.1.2.0

# Data load (load-data.sh) — 5M records x 1KB insert
MIGRATION_LOAD_NAMESPACE=test
MIGRATION_LOAD_RECORDS=5000000
MIGRATION_LOAD_OBJECT_SIZE=1024
MIGRATION_LOAD_THREADS=64

# Continuous workload (run-lab-workload.sh) — 10k TPS, RU,50 read/write
WORKLOAD_TPS=10000
WORKLOAD_THREADS=64
WORKLOAD_NAMESPACE=test
WORKLOAD_RECORDS=5000000
WORKLOAD_OBJECT_SIZE=1024
WORKLOAD_DURATION=86400

# Section 3 — Aerospike client TLS (load-data.sh / run-lab-workload.sh)
# AEROSPIKE_TLS_MODE: plain | tls | pki  (or pass --tls / --pki on the script)
AEROSPIKE_TLS_MODE=plain
AEROSPIKE_TLS_NAME=aerocluster
AEROSPIKE_TLS_PORT=4333
TLS_CLUSTER_NAME=aerocluster
